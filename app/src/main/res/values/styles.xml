<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="CyberTableHeader">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">46dp</item>
        <item name="android:background">@drawable/bg_table_header</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:textColor">@color/cyber_yellow</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CyberTableCell">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:background">@drawable/bg_table_cell</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:minWidth">90dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:textColor">@color/cyber_text</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="CyberActionCell">
        <item name="android:layout_width">150dp</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:background">@drawable/bg_table_cell</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
    </style>

    <style name="CyberActionCellInactive" parent="CyberActionCell">
        <item name="android:background">@drawable/bg_table_cell_inactive</item>
    </style>

    <style name="CyberActionButton">
        <item name="android:layout_width">42dp</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:layout_marginEnd">6dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CyberTableCellInactive" parent="CyberTableCell">
        <item name="android:background">@drawable/bg_table_cell_inactive</item>
        <item name="android:textColor">#FFFFC9D3</item>
    </style>

    <style name="CyberEditButton" parent="CyberActionButton">
        <item name="android:background">@drawable/bg_button_outline_cyan</item>
        <item name="android:textColor">@color/cyber_cyan</item>
    </style>

    <style name="CyberDeleteButton" parent="CyberActionButton">
        <item name="android:background">@drawable/bg_button_outline_magenta</item>
        <item name="android:textColor">@color/cyber_magenta</item>
    </style>

    <style name="CyberToggleButton" parent="CyberActionButton">
        <item name="android:background">@drawable/bg_button_outline_yellow</item>
        <item name="android:textColor">@color/cyber_yellow</item>
    </style>

    <style name="CyberOrderHeader" parent="CyberTableHeader">
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="CyberOrderCell" parent="CyberTableCell">
        <item name="android:height">68dp</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="CyberOrderSubtotal" parent="CyberOrderCell">
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/cyber_text</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CyberQuantityCell">
        <item name="android:layout_width">176dp</item>
        <item name="android:layout_height">68dp</item>
        <item name="android:background">@drawable/bg_table_cell</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
    </style>

    <style name="CyberQtyButton">
        <item name="android:layout_width">42dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:background">@drawable/bg_qty_button</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:textColor">#FF07351F</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CyberQtyValue">
        <item name="android:layout_width">62dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_marginStart">8dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/bg_qty_value</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/cyber_yellow</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
