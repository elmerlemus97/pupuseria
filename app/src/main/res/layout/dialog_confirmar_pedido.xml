<?xml version="1.0" encoding="utf-8"?>
<!-- Layout para el Diálogo de Confirmación de Pedido -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    android:background="@drawable/bg_dialog_confirm"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Título del Diálogo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Confirmación del Pedido"
            android:textColor="@color/cyber_magenta"
            android:textSize="20sp"
            android:textStyle="bold" />

        <View
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:background="@color/cyber_yellow" />
    </LinearLayout>

    <!-- Datos del Cliente -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="DATOS DEL CLIENTE"
        android:textColor="@color/cyber_cyan"
        android:textSize="12sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/edtNombreClienteConfirm"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_cyber_input"
        android:hint="Nombre del cliente"
        android:inputType="textCapWords"
        android:paddingStart="12dp"
        android:textColor="@color/cyber_text"
        android:textColorHint="@color/cyber_text_muted"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/edtTelefonoClienteConfirm"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_cyber_input"
        android:hint="Número celular"
        android:inputType="phone"
        android:paddingStart="12dp"
        android:textColor="@color/cyber_text"
        android:textColorHint="@color/cyber_text_muted"
        android:textSize="14sp" />

    <!-- Encabezados de Tabla de Resumen -->
    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp">

        <TableRow
            android:background="#1A00E5FF"
            android:padding="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1.5"
                android:text="Tipo"
                android:textColor="@color/cyber_cyan"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Cantidad"
                android:textColor="@color/cyber_cyan"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:gravity="end"
                android:text="Subtotal"
                android:textColor="@color/cyber_cyan"
                android:textStyle="bold" />
        </TableRow>

        <!-- Contenedor para filas dinámicas (se llenará en Java) -->
        <LinearLayout
            android:id="@+id/containerResumenItems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Ejemplo de fila estática (como en la imagen) -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF" />

            <TableRow android:padding="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1.5"
                    android:text="Loroco"
                    android:textColor="@color/white" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="@color/white" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="$1.50"
                    android:textColor="@color/white" />
            </TableRow>
        </LinearLayout>

    </TableLayout>

    <!-- Total General -->
    <TextView
        android:id="@+id/txtTotalConfirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Total: $6.75"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Botones de Acción -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnGuardarPedido"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_confirm"
            android:text="GUARDAR"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCerrarDialog"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_cancel"
            android:text="CERRAR"
            android:textColor="@color/white"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
