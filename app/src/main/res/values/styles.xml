<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="CyberTableHeader">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">46dp</item>
        <item name="android:background">@drawable/bg_table_header</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:textColor">@color/cyber_yellow</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CyberTableCell">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:background">@drawable/bg_table_cell</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:minWidth">90dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:textColor">@color/cyber_text</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="CyberActionCell">
        <item name="android:layout_width">280dp</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:background">@drawable/bg_table_cell</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
    </style>

    <style name="CyberActionButton">
        <item name="android:layout_width">84dp</item>
        <item name="android:layout_height">38dp</item>
        <item name="android:layout_marginEnd">6dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CyberEditButton" parent="CyberActionButton">
        <item name="android:background">@drawable/bg_button_outline_cyan</item>
        <item name="android:textColor">@color/cyber_cyan</item>
    </style>

    <style name="CyberDeleteButton" parent="CyberActionButton">
        <item name="android:background">@drawable/bg_button_outline_magenta</item>
        <item name="android:textColor">@color/cyber_magenta</item>
    </style>

    <style name="CyberToggleButton" parent="CyberActionButton">
        <item name="android:background">@drawable/bg_button_outline_yellow</item>
        <item name="android:textColor">@color/cyber_yellow</item>
    </style>
</resources>
